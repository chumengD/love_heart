image heroine_inner_cg_placeholder:
    contains:
        Solid("#f7e7ec")

    contains:
        Frame(Solid("#ffffff"), 40, 40)
        xalign 0.5
        yalign 0.5
        xysize (1320, 680)

    contains:
        Text(
            "CG 占位\n女主内心独白",
            color="#EF939E",
            size=92,
            text_align=0.5,
            font="fonts/aa幸运星.ttf"
        )
        xalign 0.5
        yalign 0.47

label Act3_heroine_view:
    scene black

    # show chapter3_heroine_view
    # with Dissolve(0.8)
    # pause 2.0
    # hide chapter3_heroine_view
    with dissolve

    show heroine_inner_cg_placeholder
    with Dissolve(0.8)

    "那天傍晚回到宿舍后，我坐在书桌前，脑海里反复回放着今天偶遇时的每一个瞬间。"
    "我点开和他的聊天框，把从婚礼初识到现在的相处，一段一段按顺序重新想了一遍。"
    g "他到底是怎么想的呢？"
    g "对我，是朋友间的照顾，还是藏着和我一样的心动？"
    "那些对话、那些小动作、那些没说出口的心情，一点点拼凑出他在我心里的样子。"

    "最开始，是微信里的第一次聊天。"
    "他打招呼的方式还有些笨拙，话题也会一不小心变得生硬。"
    "可是当他先关心我白天有没有被撞疼时，我能感觉到他的礼貌和温柔。"
    "后来他提起婚礼的捧花和缘分，语气轻松又带着一点浪漫。"
    g "第一次抢捧花还能撞到人，确实很像命运开的玩笑。"
    "如果他发来可爱的表情包，陌生感也会被一下子打破。"
    "我会忍不住觉得，他其实很有趣，也很可爱。"

    "接着，是朋友圈里的细小互动。"
    "我偶尔会发甜品、晚霞、音乐和阅读碎片，其实也在悄悄看他会不会留意。"
    "他只是点赞的时候，我会觉得至少被他看见了。"
    "他认真评论的时候，我又会觉得自己的日常被好好放在心上。"
    "如果他完全没有反应，我也会有一点失落。"

    "然后，是那节无聊的水课。"
    "老师只是照着 PPT 念，还不让我们看手机，我烦得忍不住向他吐槽。"
    "简单的加油当然也算安慰，可那种安慰很快就会飘过去。"
    "真正让我心里变暖的，是他能听懂我的累，愿意陪我慢慢写完作业。"
    "如果他发来搞笑视频，我的坏心情也会一下子被赶跑。"
    g "和他聊天，好像真的会变轻松。"

    "再后来，就是今天傍晚的校园偶遇。"
    "放学路上突然看见他，我又惊喜又紧张。"
    "如果他说只是刚好顺路，我会觉得自然又不刻意，像命运又轻轻推了我们一下。"
    "如果他说是特意等我，我会因为来得太突然而不知所措。"
    "如果他低头假装没看见，我也会有一点别扭，只好主动开口打招呼。"
    "可无论怎样，见到他的那一刻，我都没办法假装自己毫无波澜。"

    "我又想起，如果有一天我生病了，他会怎么关心我。"
    "一句多喝热水太轻了，轻到像隔着很远的礼貌。"
    "可如果他认真问我的症状，提醒我吃药、休息、垫高枕头，我一定会觉得很安心。"
    "如果他冲动地说要来找我，我会感受到他的着急，也会怕他太辛苦。"
    "如果他不只说空话，而是默默送来药、粥和暖宝宝，我大概会感动很久。"
    g "被人这样细心地照顾，原来会这么想依赖对方。"

    "最后，我想象着和他在黄昏河边散步。"
    "晚风很轻，脚步也很慢，适合把平时不好意思说出口的话一点点说出来。"
    "如果他只顾着讲自己的事，我会慢慢插不上话。"
    "如果他只是刻意夸我，夸得太满太空，我也会觉得不自在。"
    "可如果他认真听我说话，在我停顿的时候温柔回应，再分享自己的经历。"
    "那样的相处一定很安心，暧昧也会在晚风里变得越来越清楚。"

    $ act3_heroine_affection = lc_get_affection()

    if act3_heroine_affection >= 45:
        "这些回忆一点点叠起来，心动的答案已经变得很清楚。"
        g "原来我早就开始期待下一次见面了。"
        $ lc_grant_achievement("heartbeat_echo")
    elif act3_heroine_affection >= 25:
        "这些回忆一点点叠起来，我还不能完全确定他的心意。"
        g "可是只要想到他，心里还是会变得柔软。"
    else:
        "这些回忆一点点叠起来，我仍然有些犹豫。"
        g "如果想靠近我，他还需要更真诚、更细心一点。"

    "我关掉手机，趴在桌上。"
    g "下一次见面，会是什么样子呢？"

    hide heroine_inner_cg_placeholder
    with dissolve

    return
